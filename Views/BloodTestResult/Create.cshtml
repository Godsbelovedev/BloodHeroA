@using BloodHeroA.Models.Enums
@model BloodHeroA.DTOs.BloodTestResultDTO

@{
    ViewData["Title"] = "Blood Test";
    Layout = null;
}

<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<style>
    body {
        font-family: Arial, sans-serif;
        background-color: #ffe5e5;
        margin: 0;
        padding: 0;
    }

    .container {
        display: flex;
        justify-content: center;
        padding: 20px;
    }

    .card {
        width: 100%;
        max-width: 500px;
        background-color: #fff0f0;
        border-radius: 12px;
        box-shadow: 0 8px 20px rgba(179, 0, 0, 0.3);
        overflow: hidden;
    }

    .card-header {
        background-color: #b30000;
        color: white;
        padding: 18px;
        text-align: center;
        font-size: 20px;
        font-weight: bold;
    }

    .card-body {
        padding: 20px;
    }

    .form-group, .mb-3 {
        margin-bottom: 15px;
    }

    label {
        font-weight: 600;
        color: #660000;
        margin-bottom: 5px;
        display: block;
    }

    select, input, textarea {
        width: 100%;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #b30000;
        background-color: #fff5f5;
        font-size: 14px;
    }

        select:focus, input:focus, textarea:focus {
            outline: none;
            border-color: #800000;
            box-shadow: 0 0 5px rgba(179,0,0,0.5);
        }

    .btn {
        width: 100%;
        padding: 12px;
        background-color: #b30000;
        color: white;
        border: none;
        border-radius: 6px;
        font-size: 15px;
        cursor: pointer;
        margin-top: 15px;
        transition: 0.3s;
    }

        .btn:hover {
            background-color: #800000;
        }

    .alert-danger {
        background-color: #f8d7da;
        color: #842029;
        padding: 10px;
        border-radius: 5px;
        margin-bottom: 10px;
    }

    .alert-success {
        background-color: #ffd6d6;
        color: #b30000;
        padding: 10px;
        border-radius: 5px;
        margin-bottom: 10px;
    }

    .validation-error {
        color: #b30000;
        font-size: 13px;
    }

    @@media (max-width: 500px) {
        .card

    {
        border-radius: 0;
    }

    }
</style>

<div class="container">
    <div class="card">
        <div class="card-header">
            🩸 Blood Test Result
        </div>

        <div class="card-body">

            <div asp-validation-summary="All" class="validation-error"></div>

            @if (ViewBag.Error != null)
            {
                <div class="alert-danger">
                    @ViewBag.Error
                </div>
            }

            @if (TempData["success"] != null)
            {
                <div class="alert-success">
                    @TempData["success"]
                </div>
            }

            <a asp-controller="Donations"
                asp-action="GetAllUntestedDonations" class="btn-back">
                ← Back to List
            </a>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="DonationId" />
                <input type="hidden" asp-for="DonorOrganizationName" />
                <input type="hidden" asp-for="BankingOrganizationName" />

                <div class="form-group">
                    <label>Donor Name</label>
                    <input asp-for="DonorName" readonly />
                </div>

                <div class="mb-3">
                    <label asp-for="HIV" class="form-label">HIV Status</label>
                    <select asp-for="HIV" asp-items="Html.GetEnumSelectList<HealthStatus>()" class="form-control">
                        <option value="">-- Select Status --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="HepatitisB" class="form-label">Hepatitis B Status</label>
                    <select asp-for="HepatitisB" asp-items="Html.GetEnumSelectList<HealthStatus>()" class="form-control">
                        <option value="">-- Select Status --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="Syphilis" class="form-label">Syphilis Status</label>
                    <select asp-for="Syphilis" asp-items="Html.GetEnumSelectList<HealthStatus>()" class="form-control">
                        <option value="">-- Select Status --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="Cancer" class="form-label">Cancer Status</label>
                    <select asp-for="Cancer" asp-items="Html.GetEnumSelectList<HealthStatus>()" class="form-control">
                        <option value="">-- Select Status --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="Tattoo" class="form-label">Tattoo Mark</label>
                    <select asp-for="Tattoo" asp-items="Html.GetEnumSelectList<HealthStatus>()" class="form-control">
                        <option value="">-- Select Status --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="ChronicDisease" class="form-label">Chronic Disease Status</label>
                    <select asp-for="ChronicDisease" asp-items="Html.GetEnumSelectList<HealthStatus>()" class="form-control">
                        <option value="">-- Select Status --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="HeartDisease" class="form-label">Heart Disease Status</label>
                    <select asp-for="HeartDisease" asp-items="Html.GetEnumSelectList<HealthStatus>()" class="form-control">
                        <option value="">-- Select Status --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="Hemophilic" class="form-label">Hemophilic Status</label>
                    <select asp-for="Hemophilic" asp-items="Html.GetEnumSelectList<HealthStatus>()" class="form-control">
                        <option value="">-- Select Status --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="IVDrugConsumer" class="form-label">IV Drug Consumer?</label>
                    <select asp-for="IVDrugConsumer" asp-items="Html.GetEnumSelectList<HealthStatus>()" class="form-control">
                        <option value="">-- Select Status --</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label asp-for="SevereLungsDisease" class="form-label">Severe Lungs Disease Status</label>
                    <select asp-for="SevereLungsDisease" asp-items="Html.GetEnumSelectList<HealthStatus>()" class="form-control">
                        <option value="">-- Select Status --</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="TestRemark"></label>
                    <textarea asp-for="TestRemark"></textarea>
                    <span asp-validation-for="TestRemark" class="validation-error"></span>
                </div>

                <div class="form-check mb-3">
                    <label asp-for="IsHealthy" class="form-check-label"></label>
                    <input asp-for="IsHealthy" class="form-check-input" type="checkbox" />
                </div>

                <button type="submit" class="btn">
                    Submit Result
                </button>
                
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}