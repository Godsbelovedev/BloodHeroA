@model BloodHeroA.DTOs.NotificationDTO

@{
    ViewData["Title"] = "Reply Message";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Reply Message</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(135deg, #7f0000, #b30000);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .reply-card {
            background: white;
            border-radius: 15px;
            padding: 30px;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .reply-title {
            text-align: center;
            color: #b30000;
            font-weight: bold;
            margin-bottom: 20px;
        }

        .btn-blood {
            background-color: #b30000;
            color: white;
            font-weight: 600;
        }

            .btn-blood:hover {
                background-color: #8b0000;
                color: white;
            }

        .form-control:focus {
            border-color: #b30000;
            box-shadow: 0 0 0 0.2rem rgba(179,0,0,0.25);
        }
    </style>
</head>
<body>

    <div class="reply-card">

        <h3 class="reply-title">Reply Message</h3>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }

        <form asp-action="ReplyMessage" method="post">
            @Html.AntiForgeryToken()

           
            <div class="mb-3">
                <input asp-for="ReceiverEmail" type="hidden" />
            </div>

       
            <div class="mb-3">
                <label asp-for="Subject" class="form-label"></label>
                <input asp-for="Subject" class="form-control" />
                <span asp-validation-for="Subject" class="text-danger"></span>
            </div>

      
            <div class="mb-3">
                <label asp-for="Message" class="form-label"></label>
                <textarea asp-for="Message" rows="4" class="form-control"></textarea>
                <span asp-validation-for="Message" class="text-danger"></span>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-blood">
                    Send Reply
                </button>
            </div>
        </form>

    </div>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>