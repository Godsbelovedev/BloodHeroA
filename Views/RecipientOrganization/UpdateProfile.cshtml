@model BloodHeroA.DTOs.RecipientUpdateDto

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />
    <title>Profile Update</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <style>
        :root {
            --primary-red: #b30000;
            --primary-red-dark: #8a0000;
            --bg-light: #f8f9fa;
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif;
            background-color: var(--bg-light);
            min-height: 100vh;
            margin: 0;
            padding: 15px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .container {
            width: 100%;
            max-width: 500px;
            margin: 0 auto;
        }

        .card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 6px 24px rgba(0,0,0,0.12);
            overflow: hidden;
            border: none;
        }

        .card-header {
            background-color: var(--primary-red);
            color: white;
            padding: 1.5rem 1.25rem;
            text-align: center;
            font-size: 1.4rem;
            font-weight: 600;
        }

        .card-body {
            padding: 1.75rem 1.5rem;
        }

        .form-label {
            font-weight: 600;
            margin-bottom: 0.45rem;
            color: #333;
            display: block;
        }

        .form-control, .form-control:focus {
            border-radius: 6px;
            padding: 0.65rem 0.9rem;
            font-size: 1rem;
            border: 1px solid #ced4da;
            transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
        }

            .form-control:focus {
                border-color: var(--primary-red);
                box-shadow: 0 0 0 0.25rem rgba(179, 0, 0, 0.12);
            }

        textarea.form-control {
            min-height: 90px;
            resize: vertical;
        }

        .btn-primary {
            background-color: var(--primary-red);
            border: none;
            border-radius: 6px;
            padding: 0.75rem;
            font-size: 1.05rem;
            font-weight: 500;
            width: 100%;
            transition: background-color 0.2s;
        }

            .btn-primary:hover,
            .btn-primary:focus {
                background-color: var(--primary-red-dark);
            }

        .alert {
            border-radius: 6px;
            margin-bottom: 1.25rem;
            padding: 0.75rem 1rem;
            font-size: 0.95rem;
        }

        .text-danger, .validation-error {
            font-size: 0.875rem;
            margin-top: 0.25rem;
            display: block;
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 1.5rem;
            color: var(--primary-red);
            text-decoration: none;
            font-weight: 500;
        }

            .back-link:hover {
                text-decoration: underline;
            }


        @@media (max-width: 576px) {
            body {
                padding: 12px;
            }

            .card-body {
                padding: 1.4rem 1.1rem;
            }

            .card-header {
                font-size: 1.25rem;
                padding: 1.25rem 1rem;
            }

            .btn-primary {
                padding: 0.7rem;
                font-size: 1rem;
            }
        }

        @@media (min-width: 768px) {
            .container {
                max-width: 540px;
            }

            .card-body {
                padding: 2rem 2.25rem;
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="card">
            <div class="card-header">
                🩸 Update Recipient Organization Profile
            </div>

            <div class="card-body">

                @if (TempData["failure"] != null)
                {
                    <div class="alert alert-danger">@TempData["failure"]</div>
                }

                @if (TempData["success"] != null)
                {
                    <div class="alert alert-success">@TempData["success"]</div>
                }
                @if (ViewBag.Success != null)
                {
                    <div class="alert alert-warning">@ViewBag.Success</div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-warning">@ViewBag.Error</div>
                }

                <form asp-action="UpdateProfile" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="OrganizationName" class="form-label">Organization Name</label>
                        <input asp-for="OrganizationName" class="form-control" placeholder="Organization name" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label">Address</label>
                        <textarea asp-for="Address" class="form-control" rows="3" placeholder="Full address of the organization"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Phone number (e.g. +234...)" />
                    </div>

                    <button type="submit" class="btn btn-primary mt-2">
                        Save Changes
                    </button>

                    <a asp-action="ViewProfile" class="btn btn-danger mt-2"> ← Back To Profile </a>

                </form>



            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.20.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>