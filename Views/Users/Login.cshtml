@model BloodHeroA.DTOs.UserLoginModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>BloodHero Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(135deg, #B22222, #DC143C);
            font-family: 'Roboto', sans-serif;
        }

        .login-card {
            width: 380px;
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 6px 15px rgba(0,0,0,0.2);
        }

            .login-card h4 {
                color: #B22222;
                font-weight: bold;
            }

        .login-icon {
            font-size: 50px;
            color: #DC143C;
        }

        .btn-login {
            background-color: #DC143C;
            border: none;
        }

            .btn-login:hover {
                background-color: #B22222;
            }

        #back-button {
            background-color: #DC143C;
            margin-top: 25px;
            color: whitesmoke;
            border-radius: 8px;
            border: none;
            text-decoration: none;
            display: block;
            text-align: center;
        }

        #back-button:hover {
                background-color: #B22222;
            }

        .links a {
            color: #B22222;
            text-decoration: none;
            font-weight: 500;
        }

            .links a:hover {
                text-decoration: underline;
            }
    </style>
</head>

<body>
    <div class="container d-flex justify-content-center align-items-center vh-100">

        <div class="card p-4 shadow login-card">

            <div class="text-center mb-2 login-icon">🩸</div>
            <h4 class="text-center mb-3">BloodHero Login</h4>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger text-center">
                    @ViewBag.Error
                </div>
            }

            @if (ViewBag.Success != null)
            {
                <div class="alert alert-danger text-center">
                    @ViewBag.Success
                </div>
            }
            
            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PassWord" class="form-label"></label>
                    <input asp-for="PassWord" type="password" class="form-control" />
                    <span asp-validation-for="PassWord" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-login w-100 text-white">
                    Login
                </button>
            </form>
            <a  asp-action="Index" asp-controller="Home" id="back-button">Back To Home Page</a>
        </div>
    </div>
</body>
</html>
