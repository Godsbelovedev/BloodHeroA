@model BloodHeroA.DTOs.RecipientOrganizationDTO

@{
    ViewData["Title"] = "Recipient Organization Registration";
    Layout = null;
}

<style>
    body {
        font-family: Arial, sans-serif;
        background-color: #f8f9fa;
    }

    .container {
        width: 100%;
        display: flex;
        justify-content: center;
        margin-top: 60px;
    }

    .card {
        width: 420px;
        background-color: white;
        border-radius: 10px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .card-header {
        background-color: #b30000;
        color: white;
        padding: 20px;
        text-align: center;
        font-size: 20px;
        font-weight: bold;
    }

    .card-body {
        padding: 25px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    label {
        display: block;
        margin-bottom: 5px;
        font-weight: 600;
    }

    input, textarea {
        width: 100%;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #ccc;
        font-size: 14px;
    }

        input:focus, textarea:focus {
            outline: none;
            border-color: #b30000;
        }

    .btn {
        width: 100%;
        padding: 12px;
        background-color: #b30000;
        color: white;
        border: none;
        border-radius: 6px;
        font-size: 15px;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn:hover {
            background-color: #800000;
        }

    .alert-danger {
        background-color: #f8d7da;
        color: #842029;
        padding: 10px;
        border-radius: 5px;
        margin-bottom: 15px;
    }

    .validation-error {
        color: red;
        font-size: 13px;
    }

</style>

<div class="container">
    <div class="card">
        <div class="card-header">
            🩸 Recipient Organization Registration
        </div>

        <div class="card-body">

            @if (ViewBag.Error != null)
            {
                <div class="alert-danger">
                    @ViewBag.Error
                </div>
            }
            @if (TempData["success"] != null)
            {
                <div class="alert-danger">
                    @TempData["success"]
                </div>
            }

            <form asp-action="CreateOrganization" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label asp-for="OrganizationName"></label>
                    <input asp-for="OrganizationName" placeholder="Enter organization name" />
                    <span asp-validation-for="OrganizationName" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" placeholder="Enter email address" />
                    <span asp-validation-for="Email" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PhoneNumber"></label>
                    <input asp-for="PhoneNumber" placeholder="Enter phone number" />
                    <span asp-validation-for="PhoneNumber" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Address"></label>
                    <textarea asp-for="Address" rows="3"
                              placeholder="Enter organization address"></textarea>
                    <span asp-validation-for="Address" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password"></label>
                    <div>
                        <input asp-for="Password" type="password" placeholder="Password"></>

                    </div>

                    <span asp-validation-for="Password" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword"></label>
                    <input asp-for="ConfirmPassword" type="password" placeholder="ConfirmPassword"></>
                    <span asp-validation-for="ConfirmPassword" class="validation-error"></span>
                </div>

                <button type="submit" class="btn">
                    Register Organization
                </button>
            </form>

        </div>
    </div>
</div>
