                   backgroundColor: ["orange","red","green"],
                   borderColor: '#fff',
                   borderWidth: 2
               }]
           },
           options: {
        responsive: true,
        plugins: {
            legend: { position: 'top' },
            datalabels: {
                color: '#fff',
