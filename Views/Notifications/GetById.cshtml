@model BloodHeroA.DTOs.NotificationResponseDto
@{
    ViewData["Title"] = "Notification Details";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Notification Details</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(135deg, #8B0000, #B22222);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .notification-card {
            background: #ffffff;
            border-radius: 15px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
            padding: 30px;
            width: 100%;
            max-width: 650px;
            animation: fadeIn 0.5s ease-in-out;
        }

        .card-header {
            text-align: center;
            margin-bottom: 20px;
        }

            .card-header h3 {
                color: #8B0000;
                font-weight: bold;
            }

        .detail-label {
            font-weight: 600;
            color: #8B0000;
        }

        .message-box {
            background-color: #fff5f5;
            border-left: 5px solid #B22222;
            padding: 15px;
            border-radius: 8px;
            margin-top: 10px;
            white-space: pre-wrap;
        }

        .btn {
            background-color: #8B0000;
            color: white;
            border-radius: 8px;
            padding: 8px 20px;
            transition: 0.3s ease;
        }

            .btn:hover {
                background-color: #B22222;
                color: white;
            }


        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(15px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media(max - width: 576px)

        {
            .notification-card

        {
            padding: 20px;
        }

        }
    </style>
</head>
<body>

    <div class="notification-card">

        <div class="card-header">
            <h3>🩸 Notification Details</h3>
        </div>

        <div class="mb-3">
            <span class="detail-label">Subject:</span>
            <div>@Model.Subject</div>
        </div>


        <div class="mb-3">
            <span class="detail-label">Date Sent:</span>
            <div>@Model.SentDate.ToString("MMMM dd, yyyy hh:mm tt")</div>
        </div>

        <div class="mb-3">
            <span class="detail-label">Sender Email:</span>
            <div>@Model.SenderEmail</div>
        </div>

        <div class="mb-3">
            <span class="detail-label">Message:</span>
            <div class="message-box">
                @Model.Message
            </div>
        </div>
        <div class="text-center mt-4">
            <a  asp-action="ReplyMessage" asp-route-id="@Model.Id" class="btn btn">
               Reply
            </a>
        </div>
        <div class="text-center mt-4">
            <a asp-action="GetNotifications" class="btn btn">
                ← Back to Notifications
            </a>
        </div>

    </div>

</body>
</html>