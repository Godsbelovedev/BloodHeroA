@model BloodHeroA.DTOs.UserDTO

@{
    Layout = null;
}
<!DOCTYPE html>
    <html>
    <head>
        <title>User Details</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    </head>
    <body>
          <h1>Viewing @(Model.FullName ?? "No") Details</h1>
     @if(TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["failure"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["failure"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if(Model != null)
    {
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@Model.FullName</h5>
                <p><strong>Email:</strong>@Model.Email</p>
                <p><strong>Date Registered:</strong>@Model.DateCreated.ToString("dd MMMM yyyy")</p>
                <p><strong>User Id:</strong>@Model.Id</p>
            </div>
        </div>
    }
    else
    {
        <p class="text-muted">No user detail to display</p>
    }
</body>
    </html>


