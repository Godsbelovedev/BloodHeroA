@model BloodHeroA.DTOs.DonationRequestResponseDto

@{
    ViewData["Title"] = "Donation Request Details";
    Layout = null; 
}

<style>
    body {
        font-family: 'Segoe UI', sans-serif;
        background-color: #fff0f0; 
    }

    .topbar {
        background: linear-gradient(90deg, #8B0000, #B22222);
        color: white;
        padding: 15px;
        text-align: center;
        font-size: 1.5rem;
        font-weight: bold;
        border-radius: 5px;
        margin-bottom: 20px;
    }

    .details-card {
        background-color: #ffe5e5;
        border: 1px solid #B22222;
        border-radius: 8px;
        padding: 20px;
        margin: auto;
        max-width: 600px;
        box-shadow: 0 0 10px rgba(178,34,34,0.3);
    }

        .details-card h4 {
            color: #8B0000;
            margin-bottom: 15px;
        }

    .details-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 10px;
        font-size: 1rem;
    }

    .details-label {
        font-weight: bold;
        color: #B22222;
    }

    #btn-back{
        background-color: #8B0000;
        color: #fff;
        border-radius: 5px;

    }
    .error-msg {
        background-color: #ffcccc;
        color: #8B0000;
        padding: 10px;
        border-radius: 5px;
        margin-bottom: 15px;
        text-align: center;
    }

    @@media (max-width: 768px) {
        .details-row

    {
        flex-direction: column;
        margin-bottom: 8px;
    }

    .details-label, .details-value {
        margin-bottom: 3px;
    }

    }
</style>

<div class="container mt-4">
    <div class="topbar">Donation Request Details</div>

    @if (ViewBag.Error != null)
    {
        <div class="error-msg">@ViewBag.Error</div>
    }

    <div class="details-card">
        <h4>Request Information</h4>

        <div class="details-row">
            <span class="details-label">Request ID:</span>
            <span class="details-value">@Model.Id</span>
        </div>

      @*   <div class="details-row">
            <span class="details-label">Banking Organization Name:</span>
            <span class="details-value">@Model.BankigOrganizationName</span>
        </div> *@

        <div class="details-row">
            <span class="details-label">Blood Group:</span>
            <span class="details-value">@Model.BloodType</span>
        </div>

        <div class="details-row">
            <span class="details-label">Units Requested:</span>
            <span class="details-value">@Model.UnitsRequested</span>
        </div>

        <div class="details-row">
            <span class="details-label">Status:</span>
            <span class="details-value">@Model.Status</span>
        </div>

        <div class="details-row">
            <span class="details-label">Request Date:</span>
            <span class="details-value">@Model.RequestDate.ToString("dd MMM yyyy")</span>
        </div>

        <div class="details-row">
            <span class="details-label">Note:</span>
            <span class="details-value">@Model.Note</span>
        </div>

        <div class="details-row">
            <span class="details-label">Recipient Organization Name:</span>
            <span class="details-value">@Model.RecipientOrganizationName</span>
        </div>
        <button onclick="history.back()" id="btn-back">
            ← Back to List
        </button>
    </div>
</div>
 @* public Guid Id { get; set; }
            public string RecipientOrganizationName { get; set; } = default!;
            public string BankigOrganizationName { get; set; } = default!;
            public BloodGroup BloodType { get; set; }
            public int UnitsRequested { get; set; }
            public DateTime RequestDate { get; set; }
            public string? Note { get; set; }
            public Status Status { get; set; } *@