@model IEnumerable<BloodHeroA.DTOs.DonorResponseDto>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Available Donors</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            background-color: #f4f6f9;
            margin: 0;
            padding: 20px;
        }

        h2 {
            text-align: center;
            color: #c0392b;
        }

        .container {
            max-width: 1200px;
            margin: auto;
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .table-wrapper {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 900px;
        }

        thead {
            background-color: #c0392b;
            color: white;
        }

        th, td {
            padding: 10px;
            text-align: left;
        }

        th {
            text-transform: uppercase;
            font-size: 13px;
        }

        tr:nth-child(even) {
            background-color: #f2f2f2;
        }

        tr:hover {
            background-color: #f9d6d5;
        }

        .btn {
            padding: 6px 10px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 12px;
            text-decoration: none;
        }

        .btn-view {
            background-color: #b71c1c;
            color: white;
        }

            .btn-view:hover {
                background-color: #7f0000;
            }

        .btn-delete {
            background-color: #e74c3c;
            color: white;
        }

            .btn-delete:hover {
                background-color: #c0392b;
            }


        @@media (max-width: 768px) {
            table {
                min-width: 100%;
            }

            thead {
                display: none;
            }

            table, tbody, tr, td {
                display: block;
                width: 100%;
            }

            tr {
                margin-bottom: 15px;
                background: white;
                border-radius: 6px;
                padding: 10px;
                box-shadow: 0 2px 6px rgba(0,0,0,0.1);
            }

            td {
                text-align: right;
                padding-left: 50%;
                position: relative;
            }

                td::before {
                    content: attr(data-label);
                    position: absolute;
                    left: 10px;
                    width: 45%;
                    text-align: left;
                    font-weight: bold;
                    color: #c0392b;
                }

            .action-buttons {
                display: flex;
                gap: 8px;
                align-items: center;
            }
        }
    </style>
</head>

<body>

    <div class="container">

        <h2>Available Donors</h2>

        <a asp-action="Dashboard"
           asp-controller="BankingOrganizationDashboard"
           class="btn btn-view my-5">
            back to dashboard
        </a>
        @if (Model == null || !Model.Any())
        {
            <p style="text-align:center;color:red;">No donor available for donations.</p>
        }
       
        else
        {
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>First Name</th>
                            <th>Middle Name</th>
                            <th>Last Name</th>
                            <th>Id</th>
                            <th>Registered Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var donor in Model)
                        {
                            <tr>
                                <td data-label="FirstName">@donor.FirstName</td>
                                <td data-label="MiddleName">@donor.MiddleName</td>
                                <td data-label="LastName">@donor.LastName</td>
                                <td data-label="Phone">@donor.PhoneNumber</td>
                                <td data-label="Date">@donor.RegisterdDate.ToString("dd, MMM yyyy HH:mm tt") </td>
                                <td data-label="Actions">
                                    <div class="action-buttons">
                                        <a asp-action="GetById"
                                           asp-route-id="@donor.Id"
                                           asp-route-source="@ViewBag.Source"
                                           class="btn btn-view">
                                            View
                                        </a>

                                        <a asp-controller="Donations"
                                           asp-action="Create"
                                           asp-route-donorId="@donor.Id"
                                           asp-route-source="@ViewBag.Source"
                                           asp-route-donorOrganizationId="@ViewBag.DonorOrganizationId"
                                           class="btn btn-view">
                                            Make Donation
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
               
            </div>
        }

    </div>

</body>
</html>