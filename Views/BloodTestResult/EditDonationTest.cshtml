@using BloodHeroA.Models.Enums
@model BloodHeroA.DTOs.BloodTestResultUpdateDTO

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blood Test Update</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --primary-red: #b30000;
            --primary-red-dark: #8a0000;
            --bg-light: #f8f9fa;
        }

        body {
            font-family: system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif;
            background-color: var(--bg-light);
            min-height: 100vh;
            margin: 0;
            padding: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            border: none;
            border-radius: 14px;
            box-shadow: 0 8px 28px rgba(0,0,0,0.12);
        }

        .card-header {
            background-color: var(--primary-red);
            color: white;
            text-align: center;
            font-weight: 600;
            font-size: 1.3rem;
            padding: 1.25rem;
        }

        .btn-primary {
            background-color: var(--primary-red);
            border: none;
        }

            .btn-primary:hover {
                background-color: var(--primary-red-dark);
            }

        textarea {
            resize: vertical;
            min-height: 100px;
        }
    </style>
</head>

<body>

    <div class="container">
        <div class="card mx-auto" style="max-width: 700px;">
            <div class="card-header">
                🩸 Blood Test Update
            </div>

            <div class="card-body p-4">

                @if (TempData["failure"] != null)
                {
                    <div class="alert alert-danger">@TempData["failure"]</div>
                }

                @if (TempData["success"] != null)
                {
                    <div class="alert alert-success">@TempData["success"]</div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-warning">@ViewBag.Error</div>
                }

                <form asp-action="UpdateProfile" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label asp-for="HIV" class="form-label"></label>
                            <select asp-for="HIV"
                                    asp-items="Html.GetEnumSelectList<HealthStatus>()"
                                    class="form-select">
                                <option value="">-- Select Status --</option>
                            </select>
                            <span asp-validation-for="HIV" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="HepatitisB" class="form-label"></label>
                            <select asp-for="HepatitisB"
                                    asp-items="Html.GetEnumSelectList<HealthStatus>()"
                                    class="form-select">
                                <option value="">-- Select Status --</option>
                            </select>
                            <span asp-validation-for="HepatitisB" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Syphilis" class="form-label"></label>
                            <select asp-for="Syphilis"
                                    asp-items="Html.GetEnumSelectList<HealthStatus>()"
                                    class="form-select">
                                <option value="">-- Select Status --</option>
                            </select>
                            <span asp-validation-for="Syphilis" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Cancer" class="form-label"></label>
                            <select asp-for="Cancer"
                                    asp-items="Html.GetEnumSelectList<HealthStatus>()"
                                    class="form-select">
                                <option value="">-- Select Status --</option>
                            </select>
                            <span asp-validation-for="Cancer" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Tattoo" class="form-label"></label>
                            <select asp-for="Tattoo"
                                    asp-items="Html.GetEnumSelectList<HealthStatus>()"
                                    class="form-select">
                                <option value="">-- Select Status --</option>
                            </select>
                            <span asp-validation-for="Tattoo" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="ChronicDisease" class="form-label"></label>
                            <select asp-for="ChronicDisease"
                                    asp-items="Html.GetEnumSelectList<HealthStatus>()"
                                    class="form-select">
                                <option value="">-- Select Status --</option>
                            </select>
                            <span asp-validation-for="ChronicDisease" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="HeartDisease" class="form-label"></label>
                            <select asp-for="HeartDisease"
                                    asp-items="Html.GetEnumSelectList<HealthStatus>()"
                                    class="form-select">
                                <option value="">-- Select Status --</option>
                            </select>
                            <span asp-validation-for="HeartDisease" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Hemophilic" class="form-label"></label>
                            <select asp-for="Hemophilic"
                                    asp-items="Html.GetEnumSelectList<HealthStatus>()"
                                    class="form-select">
                                <option value="">-- Select Status --</option>
                            </select>
                            <span asp-validation-for="Hemophilic" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="IVDrugConsumer" class="form-label"></label>
                            <select asp-for="IVDrugConsumer"
                                    asp-items="Html.GetEnumSelectList<HealthStatus>()"
                                    class="form-select">
                                <option value="">-- Select Status --</option>
                            </select>
                            <span asp-validation-for="IVDrugConsumer" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="SevereLungsDisease" class="form-label"></label>
                            <select asp-for="SevereLungsDisease"
                                    asp-items="Html.GetEnumSelectList<HealthStatus>()"
                                    class="form-select">
                                <option value="">-- Select Status --</option>
                            </select>
                            <span asp-validation-for="SevereLungsDisease" class="text-danger"></span>
                        </div>

                    </div>

                    <div class="mb-3">
                        <label asp-for="TestRemark" class="form-label"></label>
                        <textarea asp-for="TestRemark" class="form-control"></textarea>
                        <span asp-validation-for="TestRemark" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-4">
                        <label asp-for="IsHealthy" class="form-check-label"></label>
                        <input asp-for="IsHealthy" class="form-check-input" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Save Changes
                    </button>

                    <a asp-action="GetDonationsForStorage"
                       class="btn btn-outline-secondary w-100 mt-2">
                        ← Back To Donations
                    </a>

                </form>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.20.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>