@model BloodHeroA.DTOs.PasswordUpdateModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Update Password - BloodHero</title>

    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        :root {
            --blood-primary: #c1121f;
            --blood-dark: #7f0000;
            --blood-darker: #4a0000;
            --blood-bg: #0d0000;
            --card-bg: #140000;
            --text-light: #f5f5f5;
            --text-muted: #d0d0d0;
            --focus-glow: rgba(193, 18, 31, 0.4);
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(135deg, var(--blood-bg) 0%, var(--blood-darker) 100%);
            color: var(--text-light);
            font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
        }

        .blood-hero-container {
            width: 100%;
            max-width: 460px;
        }

        .blood-card {
            background: var(--card-bg);
            border: 1px solid var(--blood-dark);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.75);
        }

        .blood-header {
            background: linear-gradient(90deg, var(--blood-dark), var(--blood-primary));
            padding: 1.5rem;
            text-align: center;
            border-bottom: 1px solid var(--blood-dark);
        }

            .blood-header h3 {
                margin: 0;
                font-weight: 700;
                letter-spacing: 0.5px;
                color: white;
            }

        .card-body {
            padding: 2rem 1.75rem;
        }

        .form-label {
            color: #ffffff;
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

        .form-control {
            background-color: #1f0000;
            border: 1px solid var(--blood-dark);
            color: var(--text-light);
            border-radius: 10px;
            padding: 0.75rem 1rem;
        }

            .form-control:focus {
                background-color: #1f0000;
                border-color: var(--blood-primary);
                box-shadow: 0 0 0 0.3rem var(--focus-glow);
                color: white;
            }

        .btn-blood-hero {
            background: linear-gradient(90deg, var(--blood-primary), #e63946);
            border: none;
            font-weight: 600;
            font-size: 1.1rem;
            padding: 0.85rem 1.5rem;
            border-radius: 10px;
            transition: all 0.25s ease;
        }

            .btn-blood-hero:hover {
                background: linear-gradient(90deg, #e63946, #f44336);
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(193, 18, 31, 0.45);
            }

        .text-danger {
            font-size: 0.875rem;
        }

       
        .alert-blood-success {
            background: linear-gradient(90deg, #7f0000, var(--blood-primary));
            border: none;
            color: white;
            border-radius: 12px;
        }

        .alert-blood-danger {
            background: linear-gradient(90deg, #5a0000, #991b1b);
            border: none;
            color: white;
            border-radius: 12px;
        }

        .btn-close-white {
            filter: brightness(0) invert(1);
        }

        @@media (max-width: 576px) {
            .card-body

        {
            padding: 1.5rem 1.25rem;
        }

        .blood-header {
            padding: 1.25rem;
        }

        .btn-blood-hero {
            font-size: 1rem;
        }

        }
    </style>
</head>
<body>

    <div class="blood-hero-container">

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger alert-dismissible fade show alert-blood-danger" role="alert">
                <strong>Error:</strong> @ViewBag.Error
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show alert-blood-success" role="alert">
                @TempData["success"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["failure"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show alert-blood-danger" role="alert">
                @TempData["failure"]
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="blood-card">

            <div class="blood-header">
                <h3>Update Your Password</h3>
            </div>

            <div class="card-body">

                <form asp-action="UpdatePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label asp-for="CurrentPassword" class="form-label">Current Password</label>
                        <input asp-for="CurrentPassword" class="form-control" type="password" autocomplete="current-password" />
                        <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="NewPassword" class="form-label">New Password</label>
                        <input asp-for="NewPassword" class="form-control" type="password" autocomplete="new-password" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-blood-hero text-white">
                            Update Password
                        </button>
                    </div>
                </form>

            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>